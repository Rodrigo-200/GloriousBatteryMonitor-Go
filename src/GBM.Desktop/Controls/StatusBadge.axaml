<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GBM.Desktop.Controls.StatusBadge">

    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Ellipse Name="StatusDot" Width="8" Height="8" VerticalAlignment="Center" />
        <PathIcon Name="StatusIcon"
                  Width="14" Height="14"
                  IsVisible="False"
                  VerticalAlignment="Center"
                  Data="M11,15H6L13,1V9H18L11,23V15Z" />
        <TextBlock Name="BadgeText"
                   FontSize="13"
                   FontWeight="Medium"
                   VerticalAlignment="Center" />
    </StackPanel>

</UserControl>
