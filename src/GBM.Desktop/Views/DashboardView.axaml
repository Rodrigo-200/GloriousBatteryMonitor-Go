<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GBM.Desktop.ViewModels"
             xmlns:controls="using:GBM.Desktop.Controls"
             x:Class="GBM.Desktop.Views.DashboardView"
             x:DataType="vm:MainViewModel">

    <Panel Background="{DynamicResource WindowBackgroundBrush}">
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
              Margin="28,44,28,24">

            <!-- ── Row 0: Header (settings gear, top-right) ── -->
            <Button Grid.Row="0"
                    Classes="ghost"
                    HorizontalAlignment="Right"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip.Tip="Settings">
                <PathIcon Width="18" Height="18"
                          Foreground="{DynamicResource TextSecondaryBrush}"
                          Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" />
            </Button>

            <!-- ── Row 1: Hero Battery Arc Gauge ── -->
            <controls:BatteryGauge Grid.Row="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Width="270"
                                   Level="{Binding BatteryLevel}"
                                   IsCharging="{Binding IsCharging}"
                                   IsConnected="{Binding IsConnected}" />

            <!-- ── Row 2: Device Name + Connection Status ── -->
            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="0,4,0,24">

                <TextBlock Text="{Binding DeviceName}"
                           FontSize="15"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />

                <controls:StatusBadge HorizontalAlignment="Center"
                                      Connection="{Binding ConnectionState}"
                                      IsCharging="{Binding IsCharging}" />
            </StackPanel>

            <!-- ── Row 3: Stat Cards (2-up) ── -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,12,*"
                  Margin="0,0,0,12">

                <!-- Time Remaining -->
                <Border Grid.Column="0"
                        CornerRadius="10"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource SurfaceBorderBrush}"
                        BorderThickness="1"
                        Padding="18,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding EstimateLabel}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   LetterSpacing="0.5" />
                        <TextBlock Text="{Binding TimeRemainingText}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Charged To -->
                <Border Grid.Column="2"
                        CornerRadius="10"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource SurfaceBorderBrush}"
                        BorderThickness="1"
                        Padding="18,16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="CHARGED TO"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   LetterSpacing="0.5" />
                        <TextBlock Text="{Binding ChargedToText}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 4: Full Charge Duration Card ── -->
            <Border Grid.Row="4"
                    CornerRadius="10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    Padding="14,14"
                    Margin="0,0,0,12">
                <StackPanel Spacing="5">
                    <TextBlock Text="FULL CHARGE LASTS"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextMutedBrush}"
                               LetterSpacing="0.5" />
                    <TextBlock Text="{Binding FullChargeDurationText}"
                               FontSize="19"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- ── Row 5: Last Charge + Last Sync (full width) ── -->
            <Border Grid.Row="5"
                    CornerRadius="10"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    Padding="18,14"
                    Margin="0,0,0,12">
                <Grid RowDefinitions="Auto,10,Auto">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="LAST CHARGE"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   LetterSpacing="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastChargedText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*">
                        <TextBlock Text="LAST SYNC"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   LetterSpacing="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastSyncText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Row 6: Toast Notification ── -->
            <Border Grid.Row="6"
                    IsVisible="{Binding IsToastVisible}"
                    CornerRadius="8"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    Padding="4,0,0,0">
                <Grid ColumnDefinitions="3,Auto">
                    <Border Grid.Column="0" Width="3" CornerRadius="3,0,0,3"
                            Background="{DynamicResource AccentCyanBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ToastMessage}"
                               FontSize="12"
                               Foreground="{DynamicResource ToastTextBrush}"
                               Margin="10,8,14,8" />
                </Grid>
            </Border>

        </Grid>
    </Panel>

</UserControl>
