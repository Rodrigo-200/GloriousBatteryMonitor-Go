<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════
         DARK-MODE ONLY — This file mirrors DarkTheme.axaml
         to ensure dark appearance regardless of theme toggle.
         ══════════════════════════════════════════════════ -->

    <!-- ── FluentTheme System Accent Override ── -->
    <Color x:Key="SystemAccentColor">#00F0FF</Color>
    <Color x:Key="SystemAccentColorDark1">#00C8D6</Color>
    <Color x:Key="SystemAccentColorDark2">#00969E</Color>
    <Color x:Key="SystemAccentColorDark3">#006468</Color>
    <Color x:Key="SystemAccentColorLight1">#40F3FF</Color>
    <Color x:Key="SystemAccentColorLight2">#80F7FF</Color>
    <Color x:Key="SystemAccentColorLight3">#BFFBFF</Color>

    <!-- ── Base Surfaces ── -->
    <Color x:Key="WindowBackground">#0D0D0F</Color>
    <Color x:Key="Surface">#141418</Color>
    <Color x:Key="SurfaceBorder">#1E1E26</Color>
    <Color x:Key="SurfaceHover">#1A1A22</Color>
    <Color x:Key="Overlay">#E60D0D0F</Color>

    <!-- ── Typography ── -->
    <Color x:Key="TextPrimary">#E8E8EC</Color>
    <Color x:Key="TextSecondary">#7A7A88</Color>
    <Color x:Key="TextMuted">#3C3C48</Color>

    <!-- ── Accent ── -->
    <Color x:Key="AccentCyan">#00F0FF</Color>
    <Color x:Key="AccentCyanDim">#0A2A2E</Color>
    <Color x:Key="AccentCyanHover">#33F3FF</Color>
    <Color x:Key="AccentCyanPressed">#00BCC8</Color>

    <!-- ── Battery Arc ── -->
    <Color x:Key="BatteryGreen">#00F0FF</Color>
    <Color x:Key="BatteryAmber">#FFAA00</Color>
    <Color x:Key="BatteryRed">#FF3355</Color>
    <Color x:Key="BatteryCharging">#00F0FF</Color>
    <Color x:Key="BatteryDisconnected">#2A2A34</Color>

    <!-- ── Gauge ── -->
    <Color x:Key="GaugeTrack">#1A1A22</Color>

    <!-- ── Status Badge ── -->
    <Color x:Key="BadgeConnected">#0A2A2E</Color>
    <Color x:Key="BadgeConnectedText">#00F0FF</Color>
    <Color x:Key="BadgeDisconnected">#1E1A20</Color>
    <Color x:Key="BadgeDisconnectedText">#7A7A88</Color>
    <Color x:Key="BadgeCharging">#0A2A2E</Color>
    <Color x:Key="BadgeChargingText">#00F0FF</Color>
    <Color x:Key="BadgeConnecting">#2A2410</Color>
    <Color x:Key="BadgeConnectingText">#FFAA00</Color>
    <Color x:Key="BadgeLastKnown">#1A1A22</Color>
    <Color x:Key="BadgeLastKnownText">#7A7A88</Color>

    <!-- ── Toast ── -->
    <Color x:Key="ToastBackground">#141418</Color>
    <Color x:Key="ToastText">#E8E8EC</Color>

    <!-- ── Brushes ── -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"  Color="{DynamicResource WindowBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush"           Color="{DynamicResource Surface}" />
    <SolidColorBrush x:Key="SurfaceBorderBrush"     Color="{DynamicResource SurfaceBorder}" />
    <SolidColorBrush x:Key="SurfaceHoverBrush"      Color="{DynamicResource SurfaceHover}" />
    <SolidColorBrush x:Key="OverlayBrush"           Color="{DynamicResource Overlay}" />
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{DynamicResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{DynamicResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush"         Color="{DynamicResource TextMuted}" />
    <SolidColorBrush x:Key="AccentCyanBrush"        Color="{DynamicResource AccentCyan}" />
    <SolidColorBrush x:Key="AccentCyanDimBrush"     Color="{DynamicResource AccentCyanDim}" />
    <SolidColorBrush x:Key="GaugeTrackBrush"        Color="{DynamicResource GaugeTrack}" />
    <SolidColorBrush x:Key="ToastBackgroundBrush"   Color="{DynamicResource ToastBackground}" />
    <SolidColorBrush x:Key="ToastTextBrush"         Color="{DynamicResource ToastText}" />

</ResourceDictionary>
